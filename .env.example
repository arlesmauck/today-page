# ─── Calendars ───────────────────────────────────────────────────────────────
# Add any number of iCal (.ics) feed URLs. The prefix before _CALENDAR_URL
# can be anything — it's just a label for your own reference.
#
# Google Calendar: open calendar settings → "Integrate calendar" → copy the
#   "Secret address in iCal format" link.
# Apple/iCloud:   Calendar app → share calendar → copy link
# Outlook:        Calendar settings → "Publish a calendar" → copy ICS link
#
PERSONAL_CALENDAR_URL=https://calendar.google.com/calendar/ical/your_id/private-token/basic.ics
WORK_CALENDAR_URL=https://calendar.google.com/calendar/ical/your_work_id/private-token/basic.ics

# ─── News feeds ──────────────────────────────────────────────────────────────
# These are the default feeds built into the app. Uncomment any line to
# override a default, comment one out to remove that tab, or add new variables
# with any NEWS_FEED_*_URL name to create additional tabs.
# The tab label comes from the variable name (NEWS_FEED_LOCAL_URL → "Local").
#
NEWS_FEED_WORLD_URL=https://feeds.bbci.co.uk/news/world/rss.xml
NEWS_FEED_TECH_URL=https://feeds.arstechnica.com/arstechnica/technology-lab
NEWS_FEED_SCI_URL=https://www.sciencedaily.com/rss/top/science.xml
NEWS_FEED_HEALTH_URL=https://feeds.bbci.co.uk/news/health/rss.xml
NEWS_FEED_US_URL=https://feeds.npr.org/1001/rss.xml
#
# Local news — auto-generated from LOCATION_NAME using Google News search if not set.
# Set this to your local paper's RSS feed to get full-article AI summaries:
# NEWS_FEED_LOCAL_URL=https://your-local-paper.com/rss
#
# Add other custom tabs:
# NEWS_FEED_SPORTS_URL=https://feeds.example.com/sports.rss

# ─── AI news summarization (optional) ────────────────────────────────────────
# AI_MODEL and AI_API_KEY enable calm, fact-focused AI summaries.
# Without these, the page falls back to RSS excerpts — no other behavior change.
#
# This uses litellm, which routes requests to whichever provider you configure.
# The model string prefix tells litellm where to send the request:
#
#   OpenRouter (aggregator — access 100+ models with one API key):
#     Model format:  openrouter/{provider}/{model-name}
#     API key from:  https://openrouter.ai/keys
#     AI_MODEL=openrouter/google/gemini-2.0-flash-lite   # cheap, fast, good quality
#     AI_MODEL=openrouter/google/gemini-flash-1.5-8b     # slightly older, also good
#     AI_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct  # free tier available
#     AI_API_KEY=sk-or-...
#
#   Anthropic directly:
#     AI_MODEL=claude-haiku-4-5-20251001
#     AI_API_KEY=sk-ant-...
#
#   OpenAI directly:
#     AI_MODEL=gpt-4o-mini
#     AI_API_KEY=sk-...
#
#   Ollama (local, no API key needed):
#     AI_MODEL=ollama/llama3.2
#     AI_API_BASE=http://your-server:11434   # omit if Ollama is on localhost
#
# AI_MODEL=openrouter/google/gemini-2.0-flash-lite
# AI_API_KEY=
# AI_API_BASE=
#
# ─── Background context model (optional) ─────────────────────────────────────
# CONTEXT_MODEL enables a "Background" panel on each story card with a
# one-paragraph primer: key players, history, and why the topic matters.
# Uses the same AI_API_KEY as above (OpenRouter recommended).
#
# Perplexity models have built-in real-time web search — ideal for current facts:
#   CONTEXT_MODEL=openrouter/perplexity/sonar       # fast, ~$1/1M tokens
#   CONTEXT_MODEL=openrouter/perplexity/sonar-pro   # more thorough, higher cost
#
# Any other model works too (uses training knowledge, no web search):
#   CONTEXT_MODEL=openrouter/google/gemini-2.0-flash-lite
#
# CONTEXT_MODEL=openrouter/perplexity/sonar
#
# Max context calls per refresh cycle (default: 10). Caps cost when many new stories arrive.
# Set to 0 for unlimited. Context is skipped for lede-only stories regardless of this setting.
# CONTEXT_MAX_PER_REFRESH=10
#
# ─── AI news curation ─────────────────────────────────────────────────────────
# When enabled, the AI reviews all fetched stories and selects the most
# newsworthy ones per category. One LLM call per refresh, cached by story pool
# hash — if stories haven't changed, the LLM is not called again.
# Cost: ~$0.003/day with Gemini Flash Lite.
# A subtle "N stories set aside" count appears at the bottom of the news section.
# The curation prompt is editable via the ⚙ settings panel in the UI.
# Requires AI_API_KEY. Defaults to "true" when AI is configured.
# NEWS_CURATION_ENABLED=true
#
# ─── Google News supplementary feeds ─────────────────────────────────────────
# Supplementary Google News topic feeds broaden the candidate pool for curation.
# Stories merge into existing category tabs (World, Technology, etc.).
# Set any to "false" to disable. All enabled by default when AI is configured.
# Note: Google News stories use lede-based AI summaries (redirect URLs can't be
# fetched for full-article summaries).
# NEWS_GNEWS_WORLD=true
# NEWS_GNEWS_TECH=true
# NEWS_GNEWS_SCI=true
# NEWS_GNEWS_HEALTH=true
