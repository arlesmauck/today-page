# ─── Calendars ───────────────────────────────────────────────────────────────
# Add any number of iCal (.ics) feed URLs. The prefix before _CALENDAR_URL
# can be anything — it's just a label for your own reference.
#
# Google Calendar: open calendar settings → "Integrate calendar" → copy the
#   "Secret address in iCal format" link.
# Apple/iCloud:   Calendar app → share calendar → copy link
# Outlook:        Calendar settings → "Publish a calendar" → copy ICS link
#
PERSONAL_CALENDAR_URL=https://calendar.google.com/calendar/ical/your_id/private-token/basic.ics
WORK_CALENDAR_URL=https://calendar.google.com/calendar/ical/your_work_id/private-token/basic.ics

# ─── News feeds (optional) ───────────────────────────────────────────────────
# Default feeds are built in (Reuters World, Ars Technica Science & Tech).
# Override or add more — any NEWS_FEED_*_URL variable is loaded automatically.
#
# NEWS_FEED_WORLD_URL=https://feeds.reuters.com/reuters/topNews
# NEWS_FEED_TECH_URL=https://feeds.arstechnica.com/arstechnica/technology-lab
# NEWS_FEED_LOCAL_URL=https://your-local-paper.com/rss
