# ─── Location ────────────────────────────────────────────────────────────────
# Used for weather. Find your lat/lon at https://www.latlong.net
LATITUDE=39.7392
LONGITUDE=-104.9903
LOCATION_NAME=Denver, CO

# Timezone must be a valid IANA zone name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/Denver

# ─── Personalization ─────────────────────────────────────────────────────────
USER_NAME=Alex
PAGE_TITLE=Your Morning Paper

# ─── Calendars ───────────────────────────────────────────────────────────────
# Add any number of iCal (.ics) feed URLs. The prefix before _CALENDAR_URL
# can be anything — it's just a label for your own reference.
#
# Google Calendar: open calendar settings → "Integrate calendar" → copy the
#   "Secret address in iCal format" link.
# Apple/iCloud:   Calendar app → share calendar → copy link
# Outlook:        Calendar settings → "Publish a calendar" → copy ICS link
#
PERSONAL_CALENDAR_URL=https://calendar.google.com/calendar/ical/your_id/private-token/basic.ics
WORK_CALENDAR_URL=https://calendar.google.com/calendar/ical/your_work_id/private-token/basic.ics

# ─── News feeds ──────────────────────────────────────────────────────────────
# Default feeds are already built in (Reuters World, Ars Technica Science & Tech).
# Override them or add more — any env var matching NEWS_FEED_*_URL is loaded.
# The label shown in the tab is derived from the variable name automatically.
#
# NEWS_FEED_WORLD_URL=https://feeds.reuters.com/reuters/topNews
# NEWS_FEED_TECH_URL=https://feeds.arstechnica.com/arstechnica/technology-lab
# NEWS_FEED_LOCAL_URL=https://your-local-paper.com/rss

# ─── Server ──────────────────────────────────────────────────────────────────
# How often (in seconds) to refresh weather, calendar, and news.
REFRESH_INTERVAL=900

# Internal port the app listens on (mapped to host in docker-compose).
PORT=8080

# Where to store cached data inside the container (mount this as a volume).
DATA_DIR=/app/data
